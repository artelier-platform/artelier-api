@startuml Artelier API — Architecture

!theme plain
skinparam backgroundColor transparent
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40

skinparam package {
  BorderColor      #888780
  BackgroundColor  transparent
  FontSize         12
  FontStyle        bold
}

skinparam component {
  BorderColor      #888780
  BackgroundColor  #F1EFE8
  FontColor        #2C2C2A
  FontSize         11
}

skinparam database {
  BorderColor      #185FA5
  BackgroundColor  #E6F1FB
  FontColor        #042C53
}

skinparam cloud {
  BorderColor      #854F0B
  BackgroundColor  #FAEEDA
  FontColor        #412402
}

skinparam actor {
  BorderColor      #888780
  BackgroundColor  #F1EFE8
}

skinparam note {
  BorderColor      #D3D1C7
  BackgroundColor  #F9F8F4
  FontColor        #5F5E5A
  FontSize         10
}

skinparam arrow {
  Color            #5F5E5A
  FontSize         10
  FontColor        #888780
}

' ── Actores externos ───────────────────────────────────────────
actor "Client" as CLIENT
actor "Wompi"  as WOMPI

' ── Capa: Security ─────────────────────────────────────────────
package "Security" {
  component [JwtFilter]      as JF
  component [JwtUtil]        as JU
  component [UserPrincipal]  as UP
  component [SecurityConfig] as SECC
}

' ── Capa: Exception ────────────────────────────────────────────
package "Exception" {
  component [GlobalExceptionHandler]   as GEH
  component [ArtelierException]        as AEX
  component [OrderNotFoundException]   as OEXC
  component [PaymentNotFoundException] as PEXC
  component [InvalidOrderStateException] as IOSEXC
  component [WompiException]           as WEXC
}

' ── Capa: Controller ───────────────────────────────────────────
package "Controller" {
  component [AuthController]     as AUTHC
  component [AdminController]    as ADMINC
  component [CategoryController] as CATC
  component [ProductController]  as PRODC
  component [OrderController]    as ORDC
  component [PaymentController]  as PAYC
  component [StatsController]    as STATSC
}

' ── Capa: Service ──────────────────────────────────────────────
package "Service" {
  component [AuthService]                 as AUTHS
  component [AdminService]                as ADMINS
  component [CategoryService]             as CATS
  component [ProductService]              as PRODS
  component [OrderService]                as ORDS
  component [PaymentService]              as PAYS
  component [StatsService]                as STATS
  component [RefreshTokenService]         as REFS
  component [CloudinaryService]           as CLOUDS
  component [WompiAcceptanceTokenService] as WOMPITOK
  component [WompiSignatureValidator]     as WOMPISIG
  component [LoginAttemptService]         as LOGATT
}

' ── Capa: Integration ──────────────────────────────────────────
package "Integration" {
  component [WompiClient\n(Feign)]              as WOMPICL
  component [WompiIntegritySignatureUtil]       as WOMPIUTIL
  component [WompiAuthRequestInterceptor]       as WOMPIAUTH
  component [WompiErrorDecoder]                 as WOMPIDEC
}

' ── Capa: Mapper ───────────────────────────────────────────────
package "Mapper" {
  component [CategoryMapper]  as CATM
  component [ProductMapper]   as PRODM
  component [OrderMapper]     as ORDM
  component [PaymentMapper]   as PAYM
  component [OrderItemMapper] as ORDITMM
}

' ── Capa: Repository ───────────────────────────────────────────
package "Repository" {
  component [UserRepository]         as USERR
  component [RefreshTokenRepository] as REFTOKENR
  component [CategoryRepository]     as CATR
  component [ProductRepository]      as PRODR
  component [ProductImageRepository] as PRODIMGR
  component [OrderRepository]        as ORDR
  component [OrderItemRepository]    as ORDITEMNR
  component [PaymentRepository]      as PAYR
}

' ── Infraestructura ────────────────────────────────────────────
database "PostgreSQL 16" as DB
cloud    "Cloudinary"    as CDN
cloud    "Wompi API"     as WOMPIAPI

' ── Entrada ────────────────────────────────────────────────────

CLIENT  -->  JF      : HTTP request
WOMPI   -->  PAYC    : POST /payments/webhook\n(no JWT)

JF      ..>  JU      : validateToken / extractUsername
JF      ..>  USERR   : findByEmail
JF      ..>  UP      : build principal
JF      ..>  SECC    : configured by

JF      -->  AUTHC
JF      -->  ADMINC
JF      -->  CATC
JF      -->  PRODC
JF      -->  ORDC
JF      -->  PAYC
JF      -->  STATSC

' ── Exception handler ──────────────────────────────────────────

GEH     ..>  AUTHC   : intercepts
GEH     ..>  ADMINC  : intercepts
GEH     ..>  CATC    : intercepts
GEH     ..>  PRODC   : intercepts
GEH     ..>  ORDC    : intercepts
GEH     ..>  PAYC    : intercepts
GEH     ..>  STATSC  : intercepts
GEH     ..>  AEX     : handles
GEH     ..>  OEXC    : handles
GEH     ..>  PEXC    : handles
GEH     ..>  IOSEXC  : handles
GEH     ..>  WEXC    : handles

OEXC    --|> AEX
PEXC    --|> AEX
IOSEXC  --|> AEX

' ── Controllers → Services ─────────────────────────────────────

AUTHC   -->  AUTHS
ADMINC  -->  ADMINS
CATC    -->  CATS
PRODC   -->  PRODS
ORDC    -->  ORDS
PAYC    -->  PAYS
PAYC    -->  WOMPISIG
STATSC  -->  STATS

' ── Services → Services ────────────────────────────────────────

AUTHS   -->  REFS
AUTHS   -->  LOGATT
PAYS    -->  ORDS        : updateOrderStatusInternal
PAYS    -->  WOMPITOK
PAYS    -->  WOMPICL
PAYS    ..>  WOMPIUTIL   : generate integrity signature
WOMPITOK --> WOMPICL

' ── Services → Repositories ────────────────────────────────────

AUTHS   -->  USERR
ADMINS  -->  USERR
CATS    -->  CATR
PRODS   -->  PRODR
PRODS   -->  PRODIMGR
PRODS   -->  CATR
PRODS   -->  CLOUDS
ORDS    -->  ORDR
ORDS    -->  USERR
ORDS    -->  PRODR
PAYS    -->  PAYR
PAYS    -->  ORDR
REFS    -->  REFTOKENR
STATS   -->  ORDR
STATS   -->  ORDITEMNR
STATS   -->  PRODR

' ── Services → Mappers ─────────────────────────────────────────

CATS    ..>  CATM
PRODS   ..>  PRODM
ORDS    ..>  ORDM
ORDS    ..>  ORDITMM
PAYS    ..>  PAYM

' ── Integration interna ────────────────────────────────────────

WOMPICL ..>  WOMPIAUTH  : uses interceptor
WOMPICL ..>  WOMPIDEC   : uses error decoder

' ── Repositories → DB ──────────────────────────────────────────

USERR       -->  DB
REFTOKENR   -->  DB
CATR        -->  DB
PRODR       -->  DB
PRODIMGR    -->  DB
ORDR        -->  DB
ORDITEMNR   -->  DB
PAYR        -->  DB

' ── Servicios externos ─────────────────────────────────────────

CLOUDS      -->  CDN
WOMPICL     -->  WOMPIAPI

' ── Notas ──────────────────────────────────────────────────────

note right of JF
  Intercepta toda request entrante.
  Extrae y valida JWT con JwtUtil.
  Carga User desde UserRepository.
  Verifica ban — responde 401 si aplica.
  Construye UserPrincipal y lo inyecta
  en el SecurityContext de Spring.
  Requests sin header Authorization
  pasan al filtro de Spring Security.
end note

note right of GEH
  @RestControllerAdvice centralizado.
  Maneja: ArtelierException y subclases,
  MethodArgumentNotValidException,
  ConstraintViolationException,
  AccessDeniedException,
  HttpMessageNotReadableException,
  WompiException, Exception genérica.
end note

note right of PAYC
  POST /payments/webhook es público.
  WompiSignatureValidator verifica
  checksum SHA-256 antes de procesar.
  Eventos distintos a transaction.updated
  se ignoran con 200 OK.
end note

note right of PAYS
  Coordina con OrderService para
  transicionar estado de la orden.
  WompiIntegritySignatureUtil genera
  la firma de integridad para Wompi.
  WompiAcceptanceTokenService cachea
  tokens con @Cacheable("wompiTokens").
end note

note right of AUTHS
  LoginAttemptService aplica rate limit
  con Bucket4j (5 intentos / 5 min).
  RefreshTokenService gestiona rotación
  de tokens (single-use).
end note

note right of STATS
  Agrega datos de tres repositorios:
  ventas del mes, órdenes pendientes,
  productos activos y top producto.
end note

note bottom of DB
  Schema gestionado con Flyway.
  V1: users + refresh_tokens
  V2: categories
  V3: products + product_images
  V4: orders + order_items
  V5: payments
end note

note bottom of CDN
  CloudinaryService sube imágenes
  a la carpeta artelier/products.
  Retorna secureUrl + publicId.
end note

note bottom of WOMPIAPI
  Feign client autenticado via
  WompiAuthRequestInterceptor.
  Errores mapeados por WompiErrorDecoder
  a WompiException.
  Endpoints: merchants, transactions, PSE.
end note

@enduml